# ─────────────────────────────────────────────────────────────
# Brite MJ Technologies — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# NEVER commit `.env.local` — it is git-ignored by default.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for SEO, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://britemjtech.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role

# Resend (transactional email)
RESEND_API_KEY=your_resend_api_key
# Verified sender address on your Resend domain
RESEND_FROM_EMAIL=Brite MJ Technologies <noreply@britemjtech.com>

# Company contact details
COMPANY_PHONE=0203412477
COMPANY_WHATSAPP=0546847109
COMPANY_EMAIL=britemjtechnology@gmail.com

# Public company contact (exposed to client for click-to-call / WhatsApp)
NEXT_PUBLIC_COMPANY_PHONE=0203412477
NEXT_PUBLIC_COMPANY_PHONE_ALT=0546847109
NEXT_PUBLIC_COMPANY_WHATSAPP=233546847109
NEXT_PUBLIC_COMPANY_EMAIL=britemjtechnology@gmail.com

# Where lead/enquiry notification emails are delivered (internal inbox)
LEADS_NOTIFICATION_EMAIL=britemjtechnology@gmail.com
